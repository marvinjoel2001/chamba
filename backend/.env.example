# App
NODE_ENV=development
PORT=3000

# PostgreSQL (+ PostGIS extension should be enabled in your DB)
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=sistemas123
DATABASE_NAME=chamba
DATABASE_SYNC=true
DATABASE_SSL=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# Sessions
SESSION_SECRET=replace-with-a-secure-random-string
SESSION_TTL_SECONDS=86400

# Cloudflare R2 (S3 compatible)
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=your-r2-bucket-name
R2_REGION=auto
R2_PUBLIC_URL=

# Firebase Cloud Messaging (optional in local; required for push in production)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Paste the private key with \n escaped line breaks in a single line
FIREBASE_PRIVATE_KEY=
